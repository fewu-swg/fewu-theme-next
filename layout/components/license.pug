mixin license(post)
    .license
        .title= post.title
        - let _license = analyze_license(post.license, ctx)
        if post.properties['license-url']
            a.url(aria-label=__('Post URL(License)'),href=post.properties['license-url'])
        else 
            a.url(aria-label=__('Post URL(License)'),href=ctx.config.url+url_for(post.web_relative_path.toString()))
        if _license.type == 'create-common'
            .background!= _icon('fa-brand:fa-creative-commons')
        .announce-box
            .author
                span.label= __('Author')
                span.val= post.author

            .publish
                span.label= __('Published on')
                span.val= post.date.format('YYYY-MM-DD')
            .license-type
                span.label= __('License Agreement')
                span.val
                    if _license.type == 'creative-common'
                        - let url = 'https://creativecommons.org/licenses/'
                        - let text = 'CC '
                        - let is = (v)=>_license.value.includes(v)
                        if is('by')
                            - url += 'by-'
                            - text += 'BY-'
                        if is('nc')
                            - url += 'nc-'
                            - text += 'NC-'
                        if is('nd')
                            - url += 'nd-'
                            - text += 'ND-'
                        if is('sa')
                            - url += 'sa-'
                            - text += 'SA-'
                        - let cc_version = _license.version
                        - url = url.replace(/\-$/,'') + '/' + cc_version +'/'
                        - text = text.replace(/\-$/,'') + ' ' + cc_version
                        a.h-link(href=url)= text
                    else if _license.type === 'custom'
                        a= __('Custom license')
                    else if _license.type === 'private'
                        a= __('All rights reserved')
                    else
                        a= __('Other license')
