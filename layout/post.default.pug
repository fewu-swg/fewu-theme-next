extends global_layout.pug

append head
    meta(name="description",content=page.properties.description || page.raw_excerpt)
    meta(name="keywords",content=(page.properties.keywords||(page.categories.concat(page.tags))).join(","))
    meta(name="og:site_name",content=ctx.config.title)
    meta(name="og:url",content=ctx.config.url+url_for(page.relative_path))
    meta(name="og:type",content="article")
    meta(name="og:description",content=page.properties.description || page.raw_excerpt)
    meta(name="og:title",content=page.title)
    //- meta(data-nosplash="1")
    title #{page.title} - #{ctx.config.title}

block content
    .post-main.NeoWidget
        if page.properties.hidden
            +post-meta-minimal(page)
        else
            +post-meta-detailed(page)
        if(page.properties.image)
            .post-img
                img(src=page.properties.image,alt='The image of this article.')
        +multi-language(page)
        article#markdown_fillContent
            != page.content
        +license(page)
    if ! page.properties.disable_comment
        +giscus-widget(page)
    .next-page
        - let is_latest = page.current == 0
        - let is_earliest = page.current == (page.total - 1)
        if page.prev && page.prev.properties.hidden == true
            - let shown_prev = page.prev.prev;
            if page.current == 1
                - is_latest = true
            else
                // find last
                -
                    let previous_visible_article = page.prev;
                    while(previous_visible_article.properties.hidden) {
                        previous_visible_article = previous_visible_article.prev;
                        if(!previous_visible_article) {
                            is_latest = true;
                            break;
                        }
                    }
                    shown_prev = previous_visible_article;
            a.left(href=!is_latest&&url_for(shown_prev && shown_prev.relative_path),class=is_latest?'disabled':'--smooth')
                .arrow!= _icon('material-symbols:chevron_right','rounded')
                .title= is_latest?__('Already latest'):shown_prev.title
        else
            a.left(href=!is_latest&&url_for(page.prev.relative_path),class=is_latest?'disabled':'--smooth')
                .arrow!= _icon('material-symbols:chevron_right','rounded')
                .title= is_latest?__('Already latest'):page.prev.title
        if page.next && page.next.properties.hidden == true
            - let shown_next = page.next.next;
            if page.current == page.total -2
                - is_earliest = true
            else 
                // find last
                -
                    let next_visible_article = page.next;
                    while(next_visible_article.properties.hidden) {
                        next_visible_article = next_visible_article.prev;
                        if(!next_visible_article) {
                            is_earliest = true;
                            break;
                        }
                    }
                    shown_next = next_visible_article;
            a.right(href=!is_earliest&&url_for(shown_next && shown_next.relative_path),class=is_earliest?'disabled':'--smooth')
                .title= is_earliest?__('Already earliest'):shown_next.title
                .arrow!= _icon('material-symbols:chevron_right','rounded')
        else
            a.right(href=!is_earliest&&url_for(page.next.relative_path),class=is_earliest?'disabled':'--smooth')
                .title= is_earliest?__('Already earliest'):page.next.title
                .arrow!= _icon('material-symbols:chevron_right','rounded')
    #markdown_TOC
